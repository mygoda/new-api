# ─────────────────────────────────────────────────────────────────────────────
# new-api 生产环境配置模板
#
# 使用方式:
#   cp .env.prod.example .env.prod
#   vim .env.prod              # 按注释填写真实值
#   ./deploy.prod.sh master    # 或 slave
#
# 同一台主机要跑多个实例时，可使用多个不同的 env 文件：
#   cp .env.prod.example .env.prod.slave-1
#   ENV_FILE=.env.prod.slave-1 ./deploy.prod.sh slave
#
# ⚠️  本文件会被 deploy.prod.sh 通过 `source` 加载，凡是值中含有
#     括号 ( ) / 空格 / & / " / $ / # 等特殊字符，**必须**用单引号或双引号包裹，
#     否则 bash 会把它解析成语法错误。MySQL DSN 里的 tcp(...) 是典型案例。
#
# ⚠️  所有多节点共享项（SESSION_SECRET / CRYPTO_SECRET / SQL_DSN / REDIS_CONN_STRING
#     / DORIS_*）在 master 与所有 slave 上必须完全一致，否则会话、缓存、加密数据
#     和请求日志都会错乱。
# ─────────────────────────────────────────────────────────────────────────────

# ─── 镜像 ───────────────────────────────────────────────────────────────────
# 官方镜像（推荐）：calciumion/new-api:latest
# 也可以是自建镜像 tag: your-registry/new-api:2025-04-09
IMAGE=calciumion/new-api:latest

# ─── 容器 ───────────────────────────────────────────────────────────────────
# 容器名；留空时脚本会根据角色生成 new-api-master / new-api-slave
CONTAINER_NAME=

# 宿主机监听端口，容器内固定 3010
PORT=3010

# 容器数据目录 / 日志目录（宿主机路径，脚本会自动 mkdir -p）
# 使用外部 DB 时 /data 内只有少量缓存文件，也建议保留挂载以便排障
DATA_DIR=./data
LOGS_DIR=./logs

# Docker 网络；默认 bridge。若需加入自建 overlay / macvlan 网络，在此指定
NETWORK=bridge

# 时区
TZ=Asia/Shanghai

# ─── 存储依赖（必须由外部提供，本脚本不部署） ─────────────────────────────
# 主库连接串 —— ⚠️ MySQL 的 tcp(...) 必须加引号
#   MySQL:      'user:password@tcp(host:3306)/new_api?parseTime=true'
#   PostgreSQL: 'postgresql://user:password@host:5432/new_api'
#   ⚠️ 生产环境不要使用 SQLite（无法多节点共享）
SQL_DSN=''

# 可选：独立的请求日志库（格式同 SQL_DSN）。不填则复用 SQL_DSN
# 注意：若启用 Doris，new-api 会把请求详情写入 Doris；此处的 LOG_SQL_DSN
#       仍用于 Log 表（日志面板、配额流水、错误日志等），与 Doris 不重复
LOG_SQL_DSN=''

# Redis 连接串（多节点必填，用于热配置同步 + 内存缓存同步）
#   redis://[:password@]host:6379/0
#   rediss://…（TLS）
#   redis-sentinel://… / redis-cluster 也支持
REDIS_CONN_STRING=''

# ─── 安全密钥（多节点必须一致） ─────────────────────────────────────────────
# 会话密钥，建议 >= 32 字符。可用: openssl rand -hex 32
SESSION_SECRET=

# Redis 中敏感数据加解密密钥，建议 >= 32 字符。未设置时会回退为 SESSION_SECRET
CRYPTO_SECRET=

# ─── 集群同步 ───────────────────────────────────────────────────────────────
# 节点间缓存/配置同步间隔（秒），默认 60
SYNC_FREQUENCY=60

# 使用外部 Redis 时建议开启内存缓存，减轻 DB 压力
MEMORY_CACHE_ENABLED=true

# ─── 运行期可选参数 ────────────────────────────────────────────────────────
ERROR_LOG_ENABLED=true
BATCH_UPDATE_ENABLED=true
BATCH_UPDATE_INTERVAL=5

# 中继请求整体超时（秒），0 或留空 = 不限制
RELAY_TIMEOUT=

# ─── Doris 请求日志（可选） ─────────────────────────────────────────────────
# new-api 支持把"请求详情日志"写入 Doris（Stream Load），主业务数据仍走 SQL_DSN。
# 规则：只要 DORIS_HOST 非空即启用；留空则禁用 Doris，请求日志仍写入 SQL_DSN / LOG_SQL_DSN。
#
# ⚠️ 多节点部署：master 和所有 slave 必须指向同一套 Doris，否则请求日志会被拆散到不同库。
#
# Doris FE 地址（仅主机名/IP，不要带 http:// 前缀，不要带端口；端口由 DORIS_PORT 控制）
DORIS_HOST=

# FE HTTP 端口（Stream Load 写入使用），默认 8030；⚠️ 不要写 BE 的 8040
DORIS_PORT=8030

# FE MySQL 协议查询端口，默认 9030（new-api 查询日志时使用）
DORIS_QUERY_PORT=9030

# Doris 用户名 / 密码
DORIS_USER=root
DORIS_PASSWORD=

# Doris 数据库 / 表名（首次启用需要运维手动建库建表，参考 docs/doris-request-logs.md）
DORIS_DATABASE=new_api
DORIS_TABLE=request_logs

# 批量 flush 间隔（秒）与批量条数 —— 在延迟与 Stream Load 压力间折中
DORIS_FLUSH_INTERVAL=5
DORIS_FLUSH_BATCH_SIZE=100

# ─── 从节点专用 ─────────────────────────────────────────────────────────────
# slave 将 Web UI 请求 302 重定向到该地址（通常填主节点对外地址）
# 仅部署 slave 时生效；master 部署会自动忽略该变量
# 例: https://api.example.com
FRONTEND_BASE_URL=

# ─── 额外透传（可选） ──────────────────────────────────────────────────────
# 以逗号分隔的 KEY=VAL 列表，会按 -e 传给容器。
# 用于临时追加一些本模板未列出的环境变量，例如:
# EXTRA_ENV=STREAMING_TIMEOUT=300,GLOBAL_API_RATE_LIMIT=180
EXTRA_ENV=
